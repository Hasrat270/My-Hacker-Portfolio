---
import '../styles/global.css';
const { title = 'Root Access', description = 'Hacker portfolio built with Astro' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="page-shell">
      <slot name="nav" />
      <main class="page-content">
        <slot />
      </main>
      <footer class="page-footer">
        <div>© 2026 Root Access. Built with Astro.</div>
        <div>Zero client-side JS · Static GitHub Pages deploy</div>
      </footer>
    </div>
  </body>
</html>
