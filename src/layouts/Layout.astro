---
interface Props {
	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css">
		<style is:global>
			/* HARD FALLBACK: Even if Tailwind fails, this will stay black */
			:root {
				--hacker-green: #00ff00;
				--dark-bg: #0a0a0a;
			}
			html, body {
				background-color: var(--dark-bg) !important;
				color: var(--hacker-green) !important;
				font-family: 'Courier New', Courier, monospace;
				margin: 0;
				padding: 0;
			}
		</style>
	</head>
	<body class="min-h-screen p-4 md:p-12">
		<nav class="max-w-4xl mx-auto mb-12 border-b border-[#00ff00]/20 pb-4 flex justify-between">
			<a href="/" class="font-bold hover:bg-[#00ff00] hover:text-black px-1">HASRAT@ROOT:~$</a>
			<div class="flex gap-4">
				<a href="/machines" class="hover:underline">/machines</a>
				<a href="/writeups" class="hover:underline">/writeups</a>
			</div>
		</nav>
		<main class="max-w-4xl mx-auto">
			<slot />
		</main>
	</body>
</html>
